---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const recent = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base
  title="Jorge Prado — AI Engineer & Space Robotics Researcher"
  description="Building AI systems for production. Researching visual odometry and planetary navigation. Technical lead at Pradgar."
>

  <!-- ── NAV ── -->
  <nav class="site-nav">
    <a href="/" class="logo"><span class="blue">~/</span>jorge-prado</a>
    <div class="nav-links">
      <a href="#experience">experience</a>
      <a href="#projects">projects</a>
      <a href="#lab" class="green">lab</a>
      <a href="/blog">blog</a>
      <a href="#contact">contact</a>
    </div>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-label">jorge prado</p>
      <h1 class="hero-title">
        AI Engineer &<br />
        <span class="green">Space Robotics</span> Researcher
      </h1>
      <p class="hero-sub">
        Building production AI systems that run at the edge. Researching visual odometry
        and autonomous navigation for planetary rovers. Based in Mexico.
      </p>
      <div class="hero-links">
        <a href="#projects" class="btn-primary">projects</a>
        <a href="/blog" class="btn-secondary">writing</a>
        <a href="https://github.com/jorgepradoh" target="_blank" rel="noopener" class="btn-ghost">GitHub →</a>
      </div>
    </div>
    <div class="hero-terminal" aria-hidden="true">
      <div class="terminal-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green-dot"></span>
        <span class="terminal-title">~/jorge-prado</span>
      </div>
      <pre class="terminal-body"><span class="t-muted">$</span> <span class="t-blue">whoami</span>
<span class="t-cream">Jorge Prado — AI Engineer, Space Robotics</span>

<span class="t-muted">$</span> <span class="t-blue">ls ./interests</span>
<span class="t-green">conversational-ai</span>   <span class="t-green">visual-odometry</span>
<span class="t-green">planetary-navigation</span> <span class="t-green">cv-research</span>
<span class="t-green">saas-architecture</span>   <span class="t-green">edge-inference</span>

<span class="t-muted">$</span> <span class="t-blue">cat ./status</span>
<span class="t-amber">→ building Pradgar (AI agents for SMBs)</span>
<span class="t-amber">→ researching MSRCP for planetary VO</span>
<span class="t-muted">▋</span></pre>
    </div>
  </section>

  <!-- ── EXPERIENCE ── -->
  <section id="experience" class="section">
    <div class="section-inner">
      <h2 class="section-title"><span class="blue">./</span>experience</h2>

      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-meta">
            <span class="timeline-date">2024 — present</span>
            <span class="timeline-tag">founder</span>
          </div>
          <div class="timeline-body">
            <h3>Technical Lead · <span class="amber">Pradgar</span></h3>
            <p>
              Co-founded and built a multi-tenant SaaS platform that deploys conversational AI agents
              for SMB clients on WhatsApp. Designed the full stack: Claude-powered agents, n8n orchestration,
              Supabase/Postgres with RLS, Cal.com scheduling, and a Next.js analytics dashboard.
              First client: medical practice pilot.
            </p>
            <div class="tech-tags">
              <span>Claude API</span><span>n8n</span><span>Supabase</span><span>Twilio</span>
              <span>Next.js</span><span>Docker</span><span>Hetzner</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-meta">
            <span class="timeline-date">2023 — 2024</span>
            <span class="timeline-tag">research</span>
          </div>
          <div class="timeline-body">
            <h3>Computer Vision Research · <span class="amber">Space Robotics</span></h3>
            <p>
              Investigated image enhancement techniques for improving visual odometry accuracy on
              planetary rover datasets (MADMAX). Benchmarked MSRCP, autoMSRCR, and baseline methods
              against ATE and RPE metrics. Work targets low-texture, uneven-illumination terrain typical
              of Mars-analogue environments.
            </p>
            <div class="tech-tags">
              <span>Python</span><span>OpenCV</span><span>Visual Odometry</span>
              <span>SLAM</span><span>Planetary Navigation</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROJECTS ── -->
  <section id="projects" class="section alt">
    <div class="section-inner">
      <h2 class="section-title"><span class="blue">./</span>projects</h2>

      <div class="project-grid">
        <article class="project-card">
          <div class="project-header">
            <span class="project-icon">◈</span>
            <div class="project-links">
              <a href="https://github.com/jorgepradoh" target="_blank" rel="noopener">GitHub →</a>
            </div>
          </div>
          <h3>Pradgar — AI Agent Platform</h3>
          <p>
            Multi-tenant SaaS that deploys Claude-powered agents on WhatsApp for medical practices,
            real estate, and restaurants. Handles voice, images, appointment booking, escalations,
            and reminders. Built end-to-end: infra, orchestration, AI layer, and dashboard.
          </p>
          <div class="tech-tags">
            <span>Claude API</span><span>n8n</span><span>Supabase</span><span>WhatsApp / Twilio</span>
          </div>
        </article>

        <article class="project-card">
          <div class="project-header">
            <span class="project-icon green">◈</span>
            <div class="project-links">
              <a href="/blog/msrcp-vs-automsrcr-planetary-vo">write-up →</a>
            </div>
          </div>
          <h3>Visual Odometry — Planetary Navigation</h3>
          <p>
            Benchmarked image enhancement pre-processing (MSRCP vs autoMSRCR) on the MADMAX
            Mars-analogue dataset to reduce visual odometry drift under harsh lighting conditions.
            Measured ATE and RPE across multiple enhancement configurations.
          </p>
          <div class="tech-tags">
            <span>Python</span><span>OpenCV</span><span>VO / SLAM</span><span>MADMAX dataset</span>
          </div>
        </article>

        <article class="project-card">
          <div class="project-header">
            <span class="project-icon amber">◈</span>
          </div>
          <h3>OCR Fraud Detection Pipeline</h3>
          <p>
            Document intelligence pipeline for detecting fraudulent identity documents using OCR
            extraction combined with anomaly detection on layout, font consistency, and field
            cross-validation. Designed for high-throughput batch processing.
          </p>
          <div class="tech-tags">
            <span>Python</span><span>OCR</span><span>Computer Vision</span><span>Anomaly Detection</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ── LAB / RECENT POSTS ── -->
  <section id="lab" class="section">
    <div class="section-inner">
      <div class="lab-header">
        <div>
          <h2 class="section-title"><span class="green">./</span>lab &amp; writing</h2>
          <p class="section-sub">Experiments, paper breakdowns, and decisions worth documenting.</p>
        </div>
        <a href="/blog" class="view-all">all posts →</a>
      </div>

      {recent.length > 0 ? (
        <ul class="post-list">
          {recent.map(post => (
            <li class="post-row">
              <a href={`/blog/${post.slug}`} class="post-link">
                <div class="post-info">
                  <h3 class="post-title">{post.data.title}</h3>
                  <p class="post-desc">{post.data.description}</p>
                  <div class="post-meta-row">
                    <time datetime={post.data.date.toISOString()} class="post-date">{fmt(post.data.date)}</time>
                    <div class="post-tags">
                      {post.data.tags.slice(0, 3).map(t => <span class="tag">{t}</span>)}
                    </div>
                  </div>
                </div>
                <span class="arrow">→</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-lab">First post incoming.</p>
      )}
    </div>
  </section>

  <!-- ── CONTACT ── -->
  <section id="contact" class="section alt">
    <div class="section-inner contact-inner">
      <h2 class="section-title"><span class="blue">./</span>contact</h2>
      <p class="contact-sub">
        Open to conversations about AI systems, robotics research, and early-stage product work.
      </p>
      <div class="contact-links">
        <a href="https://github.com/jorgepradoh" target="_blank" rel="noopener" class="contact-item">
          <span class="contact-label">GitHub</span>
          <span class="contact-value">jorgepradoh →</span>
        </a>
        <a href="https://linkedin.com/in/jorge-a-prado" target="_blank" rel="noopener" class="contact-item">
          <span class="contact-label">LinkedIn</span>
          <span class="contact-value">jorge-a-prado →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="site-footer">
    <span class="footer-mono">~/jorge-prado</span>
    <span class="footer-sep">·</span>
    <span class="footer-copy">built with Astro</span>
  </footer>

</Base>

<style>
  /* ── NAV ── */
  .site-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center;
    padding: 0 clamp(1rem, 4vw, 3rem); height: 56px;
    background: rgba(13, 11, 26, 0.94);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px); gap: 2rem;
  }
  .logo {
    font-family: var(--mono); font-size: 15px; font-weight: 500;
    color: var(--cream); text-decoration: none; white-space: nowrap;
  }
  .logo:hover { text-decoration: none; }
  .nav-links {
    display: flex; gap: clamp(12px, 2vw, 24px);
    margin-left: auto; align-items: center;
  }
  .nav-links a {
    font-family: var(--mono); font-size: 13px; color: var(--mutedL);
    text-decoration: none; padding: 4px 0;
    border-bottom: 1px solid transparent;
    transition: color .2s, border-color .2s;
  }
  .nav-links a:hover { color: var(--amber); border-bottom-color: var(--amber); text-decoration: none; }
  .nav-links a.green { color: var(--green); }
  .nav-links a.green:hover { border-bottom-color: var(--green); }

  /* ── SHARED ── */
  .blue  { color: var(--blue); }
  .green { color: var(--green); }
  .amber { color: var(--amber); }

  .section { padding: 5rem clamp(1.25rem, 5vw, 3rem); }
  .section.alt { background: var(--bg2); }
  .section-inner { max-width: 900px; margin: 0 auto; }

  .section-title {
    font-family: var(--mono); font-size: 11px; letter-spacing: .2em;
    text-transform: uppercase; color: var(--muted);
    margin-bottom: 2.5rem;
  }
  .section-sub {
    font-size: 14px; color: var(--mutedL);
    margin-top: .25rem;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh; padding-top: 56px;
    display: flex; align-items: center;
    padding-left: clamp(1.25rem, 5vw, 3rem);
    padding-right: clamp(1.25rem, 5vw, 3rem);
    gap: 4rem;
    max-width: 1100px; margin: 0 auto;
  }
  .hero-inner { flex: 1; }
  .hero-label {
    font-family: var(--mono); font-size: 12px;
    color: var(--blue); letter-spacing: .25em;
    text-transform: uppercase; margin-bottom: 1.25rem;
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700; line-height: 1.1;
    letter-spacing: -.025em; color: var(--cream);
    margin-bottom: 1.5rem;
  }
  .hero-sub {
    font-size: clamp(15px, 2vw, 17px); color: var(--mutedL);
    line-height: 1.75; max-width: 480px; margin-bottom: 2.5rem;
  }
  .hero-links { display: flex; gap: 12px; flex-wrap: wrap; }

  .btn-primary {
    font-family: var(--mono); font-size: 13px;
    background: var(--amber); color: #0D0B1A;
    padding: 9px 22px; border-radius: 4px;
    font-weight: 500; text-decoration: none;
    transition: opacity .15s;
  }
  .btn-primary:hover { opacity: .85; text-decoration: none; }

  .btn-secondary {
    font-family: var(--mono); font-size: 13px;
    border: 1px solid var(--border); color: var(--mutedL);
    padding: 9px 22px; border-radius: 4px;
    text-decoration: none;
    transition: border-color .15s, color .15s;
  }
  .btn-secondary:hover { border-color: var(--mutedL); color: var(--cream); text-decoration: none; }

  .btn-ghost {
    font-family: var(--mono); font-size: 13px;
    color: var(--muted); text-decoration: none;
    padding: 9px 4px;
    transition: color .15s;
  }
  .btn-ghost:hover { color: var(--blue); text-decoration: none; }

  /* ── TERMINAL ── */
  .hero-terminal {
    flex: 0 0 340px;
    border: 1px solid var(--border);
    border-radius: 8px; overflow: hidden;
    background: var(--bg2);
    font-family: var(--mono);
  }
  .terminal-bar {
    display: flex; align-items: center; gap: 6px;
    padding: 10px 14px;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
  }
  .dot { width: 11px; height: 11px; border-radius: 50%; }
  .dot.red    { background: #FF5F57; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green-dot { background: #28C840; }
  .terminal-title {
    font-size: 11px; color: var(--muted);
    margin-left: 6px; letter-spacing: .05em;
  }
  .terminal-body {
    padding: 1.25rem 1.5rem;
    font-size: 12.5px; line-height: 1.9;
    white-space: pre; overflow-x: auto;
  }
  .t-muted  { color: var(--muted); }
  .t-blue   { color: var(--blue); }
  .t-green  { color: var(--green); }
  .t-amber  { color: var(--amber); }
  .t-cream  { color: var(--cream); }

  /* ── TIMELINE ── */
  .timeline { display: flex; flex-direction: column; gap: 0; }
  .timeline-item {
    display: grid; grid-template-columns: 180px 1fr;
    gap: 2rem; padding: 2rem 0;
    border-top: 1px solid var(--border);
  }
  .timeline-item:last-child { border-bottom: 1px solid var(--border); }
  .timeline-meta {
    display: flex; flex-direction: column; gap: .5rem;
    padding-top: .2rem;
  }
  .timeline-date {
    font-family: var(--mono); font-size: 12px; color: var(--muted);
  }
  .timeline-tag {
    font-family: var(--mono); font-size: 10px;
    color: var(--blue); background: rgba(0,182,255,.08);
    border: 1px solid rgba(0,182,255,.2);
    padding: 2px 8px; border-radius: 3px;
    text-transform: uppercase; letter-spacing: .08em;
    width: fit-content;
  }
  .timeline-body h3 {
    font-size: 1rem; font-weight: 600; color: var(--cream);
    margin-bottom: .6rem;
  }
  .timeline-body p {
    font-size: 14.5px; color: var(--mutedL);
    line-height: 1.75; margin-bottom: 1rem;
  }

  /* ── TECH TAGS ── */
  .tech-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tech-tags span {
    font-family: var(--mono); font-size: 11px;
    color: var(--muted); background: rgba(255,255,255,.04);
    border: 1px solid var(--border);
    padding: 2px 8px; border-radius: 3px;
  }

  /* ── PROJECTS ── */
  .project-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .project-card {
    border: 1px solid var(--border); border-radius: 6px;
    padding: 1.5rem; background: var(--bg);
    transition: border-color .2s;
  }
  .project-card:hover { border-color: rgba(255,255,255,.15); }
  .project-header {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 1rem;
  }
  .project-icon { font-size: 1.2rem; color: var(--blue); }
  .project-icon.green { color: var(--green); }
  .project-icon.amber { color: var(--amber); }
  .project-links a {
    font-family: var(--mono); font-size: 12px; color: var(--muted);
    text-decoration: none; transition: color .15s;
  }
  .project-links a:hover { color: var(--blue); text-decoration: none; }
  .project-card h3 {
    font-size: .95rem; font-weight: 600; color: var(--cream);
    margin-bottom: .6rem;
  }
  .project-card p {
    font-size: 13.5px; color: var(--mutedL);
    line-height: 1.7; margin-bottom: 1rem;
  }

  /* ── LAB / POSTS ── */
  .lab-header {
    display: flex; justify-content: space-between;
    align-items: flex-start; margin-bottom: 2rem;
  }
  .view-all {
    font-family: var(--mono); font-size: 12px; color: var(--muted);
    text-decoration: none; transition: color .15s; white-space: nowrap;
    margin-top: .2rem;
  }
  .view-all:hover { color: var(--green); text-decoration: none; }

  .post-list { list-style: none; }
  .post-row { border-top: 1px solid var(--border); }
  .post-row:last-child { border-bottom: 1px solid var(--border); }
  .post-link {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.5rem 0; gap: 1.5rem; text-decoration: none;
    transition: background .15s;
  }
  .post-link:hover { text-decoration: none; }
  .post-link:hover .post-title { color: var(--amber); }
  .post-link:hover .arrow { color: var(--amber); transform: translateX(4px); }
  .post-info { flex: 1; }
  .post-title {
    font-size: 1rem; font-weight: 600; color: var(--cream);
    margin-bottom: .3rem; transition: color .15s;
  }
  .post-desc {
    font-size: 13.5px; color: var(--mutedL);
    line-height: 1.6; margin-bottom: .6rem;
  }
  .post-meta-row {
    display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
  }
  .post-date { font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .post-tags { display: flex; gap: 6px; }
  .tag {
    font-family: var(--mono); font-size: 11px;
    color: var(--blue); background: rgba(0,182,255,.07);
    border: 1px solid rgba(0,182,255,.2);
    padding: 1px 7px; border-radius: 3px;
  }
  .arrow {
    color: var(--muted); font-size: 18px;
    flex-shrink: 0; transition: color .15s, transform .15s;
  }
  .empty-lab { font-family: var(--mono); font-size: 13px; color: var(--muted); }

  /* ── CONTACT ── */
  .contact-inner { max-width: 600px; }
  .contact-sub {
    font-size: 15px; color: var(--mutedL); line-height: 1.75;
    margin-bottom: 2rem;
  }
  .contact-links { display: flex; flex-direction: column; gap: 0; }
  .contact-item {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.1rem 0; border-top: 1px solid var(--border);
    text-decoration: none; transition: background .15s;
  }
  .contact-item:last-child { border-bottom: 1px solid var(--border); }
  .contact-item:hover { text-decoration: none; }
  .contact-item:hover .contact-value { color: var(--blue); }
  .contact-label { font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .contact-value { font-family: var(--mono); font-size: 13px; color: var(--mutedL); transition: color .15s; }

  /* ── FOOTER ── */
  .site-footer {
    padding: 2rem clamp(1.25rem, 5vw, 3rem);
    display: flex; align-items: center; gap: .75rem;
    border-top: 1px solid var(--border);
  }
  .footer-mono { font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .footer-sep  { color: var(--border); }
  .footer-copy { font-size: 12px; color: var(--muted); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .hero { flex-direction: column; padding-top: 80px; gap: 2.5rem; min-height: auto; padding-bottom: 4rem; }
    .hero-terminal { flex: none; width: 100%; max-width: 480px; }
  }
  @media (max-width: 640px) {
    .nav-links { display: none; }
    .timeline-item { grid-template-columns: 1fr; gap: .75rem; }
    .timeline-meta { flex-direction: row; align-items: center; gap: .75rem; }
    .lab-header { flex-direction: column; gap: .75rem; }
  }
</style>
